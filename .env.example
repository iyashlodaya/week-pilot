# ─── LLM Provider ──────────────────────────────────────────
# Which LLM backend to use: ollama | gemini | openai
LLM_PROVIDER=ollama
# ─── OpenAI ────────────────────────────────────────────────
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# ─── Gemini ────────────────────────────────────────────────
# Required when LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key


# model choice for each llm provider
OLLAMA_MODEL=gemma4
# GEMINI_MODEL=
# OPENAI_MODEL=

# ─── General ───────────────────────────────────────────────
# Optional: Comma-separated paths to git repos to track
WEEKPILOT_REPOS=/path/to/repo1,/path/to/repo2

# Optional: Directory containing daily note files (.md, .txt)
WEEKPILOT_NOTES_DIR=~/notes

# Optional: Directory for WeekPilot data (database, outputs)
WEEKPILOT_DATA_DIR=~/.weekpilot
