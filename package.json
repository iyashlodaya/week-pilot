{
  "name": "weekpilot",
  "version": "0.1.0",
  "description": "A lightweight AI agent that tracks your engineering work and generates standup updates & weekly summaries",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "weekpilot": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "standup",
    "weekly-summary",
    "ai-agent",
    "engineering-tools",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.3",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "openai": "^6.39.0",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
